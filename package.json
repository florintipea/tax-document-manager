{
  "name": "tax-document-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:generate && next dev -H localhost -p 3000",
    "build": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma generate && next build",
    "start": "next start -H 0.0.0.0",
    "start:production": "sh scripts/start-production.sh",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:create-admin": "tsx scripts/create-admin.ts",
    "db:create-test-accounts": "tsx scripts/create-test-accounts.ts",
    "db:verify-test-accounts": "node scripts/verify-test-accounts.mjs",
    "db:reset-password": "tsx scripts/reset-password.ts",
    "test:end-phase": "tsx scripts/end-test-phase.ts",
    "test:reactivate-phase": "tsx scripts/reactivate-test-phase.ts",
    "cloud:launch": "node scripts/launch-cloud.mjs",
    "cloud:docker-test": "docker build -t taxdoc-beta:local . && docker run --rm -p 3001:3000 -e PORT=3000 -e TEST_PHASE_ENABLED=true taxdoc-beta:local",
    "github:prepare": "node scripts/prepare-github-upload.mjs",
    "github:push": "node scripts/github-push.mjs",
    "render:deploy": "node scripts/render-deploy.mjs",
    "launch:all": "node scripts/launch-all.mjs",
    "smoke:test": "node scripts/smoke-test.mjs",
    "dev:mobile": "npm run db:generate && next dev -H 0.0.0.0 -p 3000",
    "mobile:icons": "node scripts/generate-pwa-icons.mjs",
    "mobile:build": "node scripts/build-mobile-packages.mjs",
    "mobile:setup": "node scripts/setup-android-build.mjs",
    "mobile:apk": "bash scripts/build-android-apk.sh",
    "mobile:cloud": "node scripts/build-mobile-packages.mjs",
    "test:setup": "npm run db:create-test-accounts && npm run db:verify-test-accounts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.929.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.0.0",
    "@langchain/google-genai": "^1.0.0",
    "@langchain/openai": "^1.1.0",
    "@prisma/client": "^6.19.0",
    "@tanstack/react-query": "^5.90.8",
    "@tanstack/react-query-devtools": "^5.90.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.0.4",
    "lucide-react": "^0.553.0",
    "multer": "^2.0.2",
    "next": "16.0.2",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.5.3",
    "openai": "^6.8.1",
    "otpauth": "^9.5.1",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.19.0",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.4.1",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.4.0",
    "tesseract.js": "^6.0.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.0.8",
    "eslint": "^9",
    "eslint-config-next": "^16.0.2",
    "isomorphic-git": "^1.38.5",
    "playwright": "^1.56.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
